DATABASE_URL=postgresql+psycopg://beyou:beyou_dev_password@localhost:15432/beyou
ENVIRONMENT=development
RUNTIME_MODE=local_demo
SESSION_COOKIE_NAME=beyou_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_MAX_AGE_SECONDS=86400
FRONTEND_ORIGIN=http://localhost:3000
FRONTEND_ORIGINS=http://127.0.0.1:3000
ALLOW_DEMO_SEED=true
ALLOW_DEMO_LOGIN=true
SOS_EMAIL_PROVIDER=disabled
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
SMTP_TIMEOUT_SECONDS=10

# Web Push notifications (VAPID)
WEB_PUSH_VAPID_PUBLIC_KEY=replace-with-vapid-public-key
WEB_PUSH_VAPID_PRIVATE_KEY=replace-with-vapid-private-key
WEB_PUSH_SUBJECT=mailto:admin@example.com
